# Production image for Railway (dev-server mode — minimal change from local).
# Build context is the REPOSITORY ROOT, so COPY paths are prefixed with frontend/.
FROM node:20-slim
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install
COPY frontend/ .
# Railway injects PORT; fall back to 5173 for local `docker build/run` tests.
CMD ["sh", "-c", "npm run dev -- --host 0.0.0.0 --port ${PORT:-5173}"]
